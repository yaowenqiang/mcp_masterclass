[project]
name = "screenshot-mcp-server"
version = "0.1.0"
description = "MCP Server for taking screenshots on macOS"
readme = "README.md"
requires-python = ">=3.10"
dependencies = [
    "mcp>=0.9.0",
]

[build-system]
requires = [ "setuptools>=61.0",]
build-backend = "setuptools.build_meta"

[project.scripts]
screenshot-server = "screenshot_server:main"
